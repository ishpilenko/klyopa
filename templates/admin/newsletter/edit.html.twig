<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Edit Issue #{{ issue.id }} — Admin</title>
    <style>
        *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
        body{font-family:system-ui,-apple-system,sans-serif;background:#f3f4f6;color:#1f2937;font-size:.9rem}
        .wrap{max-width:1400px;margin:0 auto;padding:1.5rem}
        .page-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;flex-wrap:wrap;gap:.75rem}
        .page-header h1{font-size:1.25rem;font-weight:700}
        .back{font-size:.875rem;color:#6b7280;text-decoration:none}
        .layout{display:grid;grid-template-columns:1fr;gap:1.5rem}
        @media(min-width:1100px){.layout{grid-template-columns:1fr 1fr}}
        .card{background:#fff;border-radius:10px;box-shadow:0 1px 6px rgba(0,0,0,.07);padding:1.5rem}
        .field{margin-bottom:1.25rem}
        label{display:block;font-size:.8rem;font-weight:600;color:#374151;margin-bottom:.375rem;text-transform:uppercase;letter-spacing:.04em}
        input[type=text],input[type=email],textarea{width:100%;padding:.625rem .875rem;border:1px solid #d1d5db;border-radius:6px;font-size:.9rem;font-family:inherit}
        input:focus,textarea:focus{border-color:#6366f1;outline:none;box-shadow:0 0 0 3px rgba(99,102,241,.12)}
        textarea{resize:vertical}
        .hint{font-size:.75rem;color:#9ca3af;margin-top:.25rem}
        .badge{display:inline-block;padding:.2rem .7rem;border-radius:20px;font-size:.75rem;font-weight:600;text-transform:uppercase}
        .badge-draft{background:#f3f4f6;color:#374151}
        .badge-ready{background:#dbeafe;color:#1d4ed8}
        .badge-sent{background:#d1fae5;color:#065f46}
        .badge-sending{background:#fef3c7;color:#92400e}
        .btn{padding:.6rem 1.25rem;border-radius:6px;font-weight:600;cursor:pointer;font-size:.875rem;border:none}
        .btn-primary{background:#6366f1;color:#fff}
        .btn-primary:hover{background:#4f46e5}
        .btn-secondary{background:#fff;color:#374151;border:1px solid #d1d5db}
        .btn-danger{background:#dc2626;color:#fff}
        .btn-danger:hover{background:#b91c1c}
        .section-title{font-size:.8rem;font-weight:700;text-transform:uppercase;letter-spacing:.04em;color:#6b7280;margin-bottom:1rem;padding-bottom:.5rem;border-bottom:1px solid #e5e7eb}
        .test-row{display:flex;gap:.625rem;margin-bottom:.5rem}
        .test-row input{flex:1}
        #test-result{font-size:.8rem;min-height:1.2rem;margin-top:.25rem}
        .send-box{margin-top:1.5rem;padding:1.25rem;background:#fff8f1;border:1px solid #fed7aa;border-radius:8px}
        .send-box h3{margin-bottom:.5rem;font-size:.9rem}
        .send-box p{font-size:.8rem;color:#6b7280;margin-bottom:.875rem}
        .preview-wrap{position:sticky;top:1rem}
        iframe{width:100%;height:700px;border:1px solid #e5e7eb;border-radius:8px}
    </style>
</head>
<body>
<div class="wrap">
    <div class="page-header">
        <div>
            <a href="{{ path('admin_newsletter_issues') }}" class="back">← Issues</a>
            <h1 style="margin-top:.25rem">
                Issue #{{ issue.id }}
                <span class="badge badge-{{ issue.status.value }}" style="vertical-align:middle;margin-left:.5rem">{{ issue.status.value }}</span>
            </h1>
        </div>
        <a href="{{ path('admin_newsletter_preview', {id: issue.id}) }}" target="_blank" class="btn btn-secondary">Open Preview ↗</a>
    </div>

    {% for type, messages in app.flashes %}
        {% for msg in messages %}
            <div style="padding:.75rem 1rem;border-radius:6px;margin-bottom:1rem;background:{{ type=='success' ? '#d1fae5' : '#fee2e2' }};color:{{ type=='success' ? '#065f46' : '#991b1b' }};border:1px solid {{ type=='success' ? '#a7f3d0' : '#fecaca' }}">
                {{ msg }}
            </div>
        {% endfor %}
    {% endfor %}

    <div class="layout">
        {# Editor form #}
        <div>
            <div class="card">
                <form method="post" action="{{ path('admin_newsletter_edit', {id: issue.id}) }}" id="issue-form">
                    <div class="field">
                        <label>Subject</label>
                        <input type="text" name="subject" value="{{ issue.subject }}" maxlength="255" required>
                        <p class="hint">{{ issue.subject|length }}/255 chars — shown in inbox subject line</p>
                    </div>
                    <div class="field">
                        <label>Preview Text</label>
                        <input type="text" name="preview_text" value="{{ issue.previewText ?? '' }}" maxlength="150">
                        <p class="hint">Shows after subject in most email clients (max 150 chars)</p>
                    </div>
                    <div class="field">
                        <label>HTML Content</label>
                        <textarea name="content_html" rows="22" id="content-editor"
                                  oninput="refreshPreview()">{{ issue.contentHtml }}</textarea>
                    </div>
                    <button type="submit" class="btn btn-primary">Save as Ready</button>
                </form>
            </div>

            {# Test send #}
            <div class="card" style="margin-top:1rem">
                <p class="section-title">Test Send</p>
                <div class="test-row">
                    <input type="email" id="test-email" placeholder="your@email.com">
                    <button class="btn btn-secondary" onclick="sendTest()">Send Test</button>
                </div>
                <div id="test-result"></div>
            </div>

            {# Send to all #}
            {% if issue.status.value == 'ready' %}
            <div class="send-box">
                <h3>Send to All Subscribers</h3>
                <p>This will send the newsletter to all <strong>active</strong> subscribers. This action cannot be undone.</p>
                <form method="post" action="{{ path('admin_newsletter_send', {id: issue.id}) }}"
                      onsubmit="return confirm('Send this issue to ALL active subscribers? This cannot be undone.')">
                    <button type="submit" class="btn btn-danger">🚀 Send Newsletter</button>
                </form>
            </div>
            {% endif %}
        </div>

        {# Preview pane #}
        <div class="preview-wrap">
            <iframe id="preview-iframe" src="{{ path('admin_newsletter_preview', {id: issue.id}) }}"></iframe>
        </div>
    </div>
</div>

<script>
var debounceTimer;
function refreshPreview() {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(function () {
        var iframe = document.getElementById('preview-iframe');
        var content = document.getElementById('content-editor').value;
        var blob = new Blob([content], { type: 'text/html' });
        var url = URL.createObjectURL(blob);
        iframe.src = url;
    }, 600);
}

function sendTest() {
    var email  = document.getElementById('test-email').value;
    var result = document.getElementById('test-result');
    if (!email) return;
    result.textContent = 'Sending…';
    fetch('{{ path('admin_newsletter_send_test', {id: issue.id}) }}', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'email=' + encodeURIComponent(email),
    })
    .then(function(r) { return r.json(); })
    .then(function(d) {
        result.textContent = d.message || d.error;
        result.style.color = d.message ? 'var(--color-positive, #16a34a)' : '#dc2626';
    });
}
</script>
</body>
</html>
