{% extends '@EasyAdmin/page/content.html.twig' %}

{% block page_title %}Dashboard{% endblock %}

{% block main %}
<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1.5rem;margin-bottom:2rem">

    <a href="{{ ea_url().setController('App\\Controller\\Admin\\ArticleCrudController').generateUrl() }}"
       style="background:#fff;border-radius:8px;padding:1.5rem;text-decoration:none;color:#1a1a2e;box-shadow:0 1px 4px rgba(0,0,0,.1);transition:box-shadow .2s"
       onmouseover="this.style.boxShadow='0 4px 12px rgba(0,0,0,.15)'" onmouseout="this.style.boxShadow='0 1px 4px rgba(0,0,0,.1)'">
        <div style="font-size:2rem;margin-bottom:.5rem">📰</div>
        <strong>Articles</strong>
        <p style="font-size:.85rem;color:#6b7280;margin:.25rem 0 0">Manage all content</p>
    </a>

    <a href="{{ ea_url().setController('App\\Controller\\Admin\\ContentQueueCrudController').generateUrl() }}"
       style="background:#fff;border-radius:8px;padding:1.5rem;text-decoration:none;color:#1a1a2e;box-shadow:0 1px 4px rgba(0,0,0,.1);transition:box-shadow .2s"
       onmouseover="this.style.boxShadow='0 4px 12px rgba(0,0,0,.15)'" onmouseout="this.style.boxShadow='0 1px 4px rgba(0,0,0,.1)'">
        <div style="font-size:2rem;margin-bottom:.5rem">⏰</div>
        <strong>Content Queue</strong>
        <p style="font-size:.85rem;color:#6b7280;margin:.25rem 0 0">AI generation tasks</p>
    </a>

    <a href="{{ ea_url().setController('App\\Controller\\Admin\\CategoryCrudController').generateUrl() }}"
       style="background:#fff;border-radius:8px;padding:1.5rem;text-decoration:none;color:#1a1a2e;box-shadow:0 1px 4px rgba(0,0,0,.1);transition:box-shadow .2s"
       onmouseover="this.style.boxShadow='0 4px 12px rgba(0,0,0,.15)'" onmouseout="this.style.boxShadow='0 1px 4px rgba(0,0,0,.1)'">
        <div style="font-size:2rem;margin-bottom:.5rem">📁</div>
        <strong>Categories</strong>
        <p style="font-size:.85rem;color:#6b7280;margin:.25rem 0 0">Organize content</p>
    </a>

    <a href="{{ ea_url().setController('App\\Controller\\Admin\\MediaCrudController').generateUrl() }}"
       style="background:#fff;border-radius:8px;padding:1.5rem;text-decoration:none;color:#1a1a2e;box-shadow:0 1px 4px rgba(0,0,0,.1);transition:box-shadow .2s"
       onmouseover="this.style.boxShadow='0 4px 12px rgba(0,0,0,.15)'" onmouseout="this.style.boxShadow='0 1px 4px rgba(0,0,0,.1)'">
        <div style="font-size:2rem;margin-bottom:.5rem">🖼️</div>
        <strong>Media</strong>
        <p style="font-size:.85rem;color:#6b7280;margin:.25rem 0 0">Images & files</p>
    </a>

    <a href="{{ ea_url().setController('App\\Controller\\Admin\\SiteCrudController').generateUrl() }}"
       style="background:#fff;border-radius:8px;padding:1.5rem;text-decoration:none;color:#1a1a2e;box-shadow:0 1px 4px rgba(0,0,0,.1);transition:box-shadow .2s"
       onmouseover="this.style.boxShadow='0 4px 12px rgba(0,0,0,.15)'" onmouseout="this.style.boxShadow='0 1px 4px rgba(0,0,0,.1)'">
        <div style="font-size:2rem;margin-bottom:.5rem">🌐</div>
        <strong>Sites</strong>
        <p style="font-size:.85rem;color:#6b7280;margin:.25rem 0 0">Multi-site settings</p>
    </a>

</div>

<div style="background:#fff;border-radius:8px;padding:1.5rem;box-shadow:0 1px 4px rgba(0,0,0,.1)">
    <h3 style="margin-top:0;font-size:1rem;color:#6b7280;text-transform:uppercase;letter-spacing:.07em">Quick access</h3>
    <ul style="margin:0;padding-left:1.25rem;line-height:2">
        <li><a href="{{ ea_url().setController('App\\Controller\\Admin\\ArticleCrudController').setAction('new').generateUrl() }}">+ New Article</a></li>
        <li><a href="{{ ea_url().setController('App\\Controller\\Admin\\ContentQueueCrudController').setAction('new').generateUrl() }}">+ Add to Queue</a></li>
        <li><a href="{{ ea_url().setController('App\\Controller\\Admin\\CategoryCrudController').setAction('new').generateUrl() }}">+ New Category</a></li>
    </ul>
</div>
{% endblock %}
