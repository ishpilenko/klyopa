<!DOCTYPE html>
<html lang="{{ site.locale ?? 'en' }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    {# ── Title ─────────────────────────────────────────────── #}
    <title>{% block title %}{{ meta_title ?? site.defaultMetaTitle ?? site.name }}{% endblock %}</title>

    {# ── Meta description ──────────────────────────────────── #}
    {% block meta_description %}
        {% set desc = meta_description ?? site.defaultMetaDescription %}
        {% if desc %}<meta name="description" content="{{ desc|striptags|trim|slice(0, 155) }}">{% endif %}
    {% endblock %}

    {# ── Canonical ─────────────────────────────────────────── #}
    {% block canonical %}
        <link rel="canonical" href="{{ app.request.schemeAndHttpHost ~ app.request.pathInfo }}">
    {% endblock %}

    {# ── Robots ────────────────────────────────────────────── #}
    {% block robots %}<meta name="robots" content="index, follow">{% endblock %}

    {# ── Open Graph ────────────────────────────────────────── #}
    {% block open_graph %}
        <meta property="og:site_name" content="{{ site.name }}">
        <meta property="og:locale"    content="{{ site.locale }}">
        <meta property="og:type"      content="{% block og_type %}website{% endblock %}">
        <meta property="og:url"       content="{{ app.request.schemeAndHttpHost ~ app.request.pathInfo }}">
        <meta property="og:title"     content="{% block og_title %}{{ block('title') }}{% endblock %}">
        <meta property="og:description" content="{% block og_description %}{{ (meta_description ?? site.defaultMetaDescription)|striptags|trim|slice(0, 200) }}{% endblock %}">
        {% block og_image %}{% endblock %}
    {% endblock %}

    {# ── Twitter Card ──────────────────────────────────────── #}
    <meta name="twitter:card"        content="summary_large_image">
    <meta name="twitter:title"       content="{{ block('og_title') }}">
    <meta name="twitter:description" content="{{ block('og_description') }}">
    {% block twitter_image %}{% endblock %}

    {# ── JSON-LD Schema ────────────────────────────────────── #}
    {% block schema_markup %}
        {{ schema_website(site, app.request.schemeAndHttpHost ~ '/') }}
    {% endblock %}

    {# ── Preconnect ────────────────────────────────────────── #}
    {% block preconnect %}{% endblock %}

    {# ── Dark mode: inline script to prevent FOUC (must be before CSS) ── #}
    <script>(function(){var t=localStorage.getItem('theme')||(document.cookie.match(/theme=(light|dark)/)||[])[1]||(window.matchMedia&&window.matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light');document.documentElement.setAttribute('data-theme',t);})();</script>

    {# ── Critical CSS (inline for above-the-fold) ──────────── #}
    {% block critical_css %}{% endblock %}

    {# ── Stylesheets ───────────────────────────────────────── #}
    {% block stylesheets %}
        <link rel="stylesheet" href="/assets/css/app.css">
    {% endblock %}

    {# ── Analytics ─────────────────────────────────────────── #}
    {% if site.analyticsId and app.environment != 'dev' %}
        <script async src="https://www.googletagmanager.com/gtag/js?id={{ site.analyticsId }}"></script>
        <script>
            window.dataLayer=window.dataLayer||[];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', {{ site.analyticsId|json_encode|raw }});
        </script>
    {% endif %}
</head>
<body class="vertical-{{ site.vertical.value }} theme-{{ site.theme }}">

    {# ── Header ────────────────────────────────────────────── #}
    {% block header %}
        <header class="site-header" role="banner" id="site-header">
            <div class="container">
                <a href="/" class="site-logo">{{ site.name }}</a>
                <nav class="site-nav" role="navigation" aria-label="Main navigation">
                    {% for cat in categories ?? [] %}
                        <a href="/{{ cat.slug }}/"
                           {% if app.request.pathInfo starts with '/' ~ cat.slug %}class="active"{% endif %}>
                            {{ cat.name }}
                        </a>
                    {% endfor %}
                </nav>
                <div class="header-actions">
                    <button id="search-toggle" class="search-toggle" aria-label="Search" title="Search (Ctrl+K)"
                        style="background:none;border:none;cursor:pointer;color:var(--header-text);padding:.25rem .5rem;opacity:.8">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
                    </svg>
                </button>
                <button class="theme-toggle" id="theme-toggle" aria-label="Switch theme">🌙</button>
                    <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">&#9776;</button>
                </div>
            </div>
        </header>
    {% endblock %}

    {# ── Flash Messages ────────────────────────────────────── #}
    {% for type, messages in app.flashes(['success', 'error', 'warning']) %}
        {% for message in messages %}
            <div class="flash flash--{{ type }}" role="alert">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    {# ── Main Content ──────────────────────────────────────── #}
    {# ── Search Overlay ── #}
    <div class="search-overlay" id="search-overlay" hidden role="dialog" aria-modal="true" aria-label="Search">
        <div class="search-overlay-inner">
            <div class="search-input-wrapper">
                <svg class="search-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
                </svg>
                <input type="search" id="search-input"
                       placeholder="Search articles, coins, tools…"
                       autocomplete="off">
                <kbd class="search-kbd">ESC</kbd>
            </div>
            <div class="search-results" id="search-results"></div>
        </div>
    </div>

    <main class="site-main" role="main" id="main-content">
        {% block body %}{% endblock %}
    </main>

    {# ── Footer ── #}
    <footer class="site-footer">
        <div class="container">
            <div class="footer-grid">
                <div>
                    <a href="/" class="footer-logo">{{ site.name }}</a>
                    <p class="footer-tagline">In-depth cryptocurrency news, analysis, and tools.</p>
                </div>
                <div>
                    <h4 class="footer-col-title">Content</h4>
                    <nav class="footer-nav">
                        {% for cat in categories ?? [] %}
                            <a href="/{{ cat.slug }}/">{{ cat.name }}</a>
                        {% endfor %}
                        <a href="/glossary">Crypto Glossary</a>
                    </nav>
                </div>
                <div>
                    <h4 class="footer-col-title">Tools</h4>
                    <nav class="footer-nav">
                        <a href="/prices">Live Prices</a>
                        <a href="/tools/converter">Converter</a>
                        <a href="/tools/crypto-profit-calculator">Profit Calculator</a>
                        <a href="/tools/dca-calculator">DCA Calculator</a>
                        <a href="/fear-greed-index">Fear &amp; Greed Index</a>
                        <a href="/tools/">All Tools</a>
                    </nav>
                </div>
                <div>
                    <h4 class="footer-col-title">Company</h4>
                    <nav class="footer-nav">
                        <a href="/about">About</a>
                        <a href="/privacy-policy">Privacy Policy</a>
                        <a href="/terms">Terms of Use</a>
                        <a href="/contact">Contact</a>
                        <a href="/sitemap.xml">Sitemap</a>
                    </nav>
                </div>
            </div>
            <div class="footer-bottom">
                <p class="footer-disclaimer">
                    The information provided on {{ site.name }} is for educational purposes only
                    and should not be considered financial advice. Always do your own research
                    before making investment decisions.
                </p>
                <p class="footer-copyright">© {{ 'now'|date('Y') }} {{ site.name }}. All rights reserved.</p>
            </div>
        </div>
    </footer>

    {% block javascripts %}
        <script src="/assets/js/app.js" defer></script>
        <script src="/assets/js/theme.js" defer></script>
        <script src="/assets/js/toc.js" defer></script>
        <script src="/assets/js/read-next.js" defer></script>
        <script src="/assets/js/search.js" defer></script>
        {# Captcha config — injected before tool-guard.js so it can read it #}
        <script>
        window.CAPTCHA_CONFIG = {
            enabled:        {{ captcha_enabled ? 'true' : 'false' }},
            sitekey:        {{ turnstile_sitekey|default('')|json_encode|raw }},
            toolsThreshold: {{ captcha_tools_threshold|default(10) }},
            nlThreshold:    1
        };
        </script>
        <script src="/assets/js/tool-guard.js" defer></script>
    {% endblock %}
</body>
</html>
