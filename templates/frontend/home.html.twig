{% extends 'base.html.twig' %}

{% block title %}{{ site.defaultMetaTitle ?? site.name }}{% endblock %}

{% block body %}

    {# ── Hero ─────────────────────────────────────── #}
    <section class="home-hero">
        <div class="container">
            <h1>{{ site.name }}</h1>
            {% if site.defaultMetaDescription %}
                <p>{{ site.defaultMetaDescription }}</p>
            {% endif %}

            {# ── Crypto: price ticker in hero ── #}
            {% if top_coins is not null and top_coins is not empty %}
                <div class="price-ticker">
                    {% for coin in top_coins|slice(0, 8) %}
                        {% set change = coin.price_change_percentage_24h ?? 0 %}
                        <a href="/price/{{ coin.id }}" class="ticker-item">
                            {% if coin.image is defined %}
                                <img src="{{ coin.image }}" alt="{{ coin.symbol|upper }}" width="18" height="18" class="ticker-icon">
                            {% endif %}
                            <span class="ticker-symbol">{{ coin.symbol|upper }}</span>
                            <span class="ticker-price">
                                {% if coin.current_price >= 1 %}
                                    ${{ coin.current_price|number_format(2) }}
                                {% else %}
                                    ${{ coin.current_price|number_format(4)|trim('0')|trim('.') }}
                                {% endif %}
                            </span>
                            <span class="ticker-change {{ change >= 0 ? 'price-up' : 'price-down' }}">
                                {{ change >= 0 ? '+' : '' }}{{ change|number_format(2) }}%
                            </span>
                        </a>
                    {% endfor %}
                    <a href="/prices" class="ticker-more">All prices →</a>
                </div>
            {% endif %}
        </div>
    </section>

    {# ── Crypto: Tools strip ─────────────────────── #}
    {% if site.vertical.value == 'crypto' %}
        <div class="container">
            <div class="home-tools-strip">
                <a href="/tools/converter" class="home-tool-card">
                    <span class="home-tool-icon">⇄</span>
                    <div>
                        <strong>Crypto Converter</strong>
                        <span>Convert BTC, ETH & 100+ coins</span>
                    </div>
                </a>
                <a href="/prices" class="home-tool-card">
                    <span class="home-tool-icon">📈</span>
                    <div>
                        <strong>Live Prices</strong>
                        <span>Real-time market data</span>
                    </div>
                </a>
                <a href="/tools/investment-calculator/bitcoin" class="home-tool-card">
                    <span class="home-tool-icon">💰</span>
                    <div>
                        <strong>Investment Calculator</strong>
                        <span>What would your investment be worth?</span>
                    </div>
                </a>
                <a href="/convert/btc-to-usd" class="home-tool-card">
                    <span class="home-tool-icon">₿</span>
                    <div>
                        <strong>BTC to USD</strong>
                        <span>Live Bitcoin price converter</span>
                    </div>
                </a>
            </div>
        </div>
    {% endif %}

    <div class="container">
        <div class="layout">
            {# ── Main column ─────────────────────── #}
            <div>

                <div class="section-header">
                    <h2>Latest Articles</h2>
                </div>

                {% if articles is not empty %}
                    <div class="article-grid">
                        {% for article in articles %}
                            {{ include('components/article_card.html.twig', {article: article}) }}
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="empty-state">
                        <h3>No articles yet</h3>
                        <p>Check back soon for the latest content.</p>
                    </div>
                {% endif %}

            </div>

            {# ── Sidebar ──────────────────────────── #}
            <aside class="sidebar">
                {% if site.vertical.value == 'crypto' %}
                    <div class="sidebar-widget">
                        <h3>Crypto Tools</h3>
                        <ul class="sidebar-links">
                            <li><a href="/prices">Live Crypto Prices</a></li>
                            <li><a href="/tools/converter">Crypto Converter</a></li>
                            <li><a href="/convert/btc-to-usd">BTC to USD</a></li>
                            <li><a href="/convert/eth-to-usd">ETH to USD</a></li>
                            <li><a href="/convert/btc-to-eth">BTC to ETH</a></li>
                            <li><a href="/tools/investment-calculator/bitcoin">Investment Calculator</a></li>
                        </ul>
                    </div>
                {% endif %}
                {{ include('components/sidebar.html.twig', {categories: categories}) }}
            </aside>
        </div>
    </div>

{% endblock %}
