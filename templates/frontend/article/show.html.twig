{% extends 'base.html.twig' %}

{% block title %}{{ meta_title ?? article.title }}{% endblock %}

{% block og_type %}article{% endblock %}
{% block og_title %}{{ meta_title ?? article.title }}{% endblock %}
{% block og_description %}{{ article.excerpt|striptags|trim|slice(0, 200) }}{% endblock %}
{% block og_image %}
    {% if article.featuredImage %}
        <meta property="og:image" content="{{ app.request.schemeAndHttpHost }}/uploads/{{ article.featuredImage.path }}">
    {% endif %}
{% endblock %}

{% block schema_markup %}
    {{ schema_article(article, site, app.request.schemeAndHttpHost) }}
    {{ schema_breadcrumb(breadcrumbs, app.request.schemeAndHttpHost) }}
{% endblock %}

{% block body %}

    {# ── Breadcrumb ─────────────────────────────── #}
    <div class="container" style="padding-top:1rem">
        {{ include('components/breadcrumb.html.twig', {items: breadcrumbs}) }}
    </div>

    <div class="container">
        <div class="layout">

            {# ── Article ─────────────────────────── #}
            <article itemscope itemtype="https://schema.org/{{ article.schemaType.value }}">

                {# Header #}
                <header class="article-header">
                    <div class="article-meta">
                        <span class="article-meta__category">
                            <a href="/{{ category.slug }}/">{{ category.name }}</a>
                        </span>
                        {% if article.publishedAt %}
                            <time datetime="{{ article.publishedAt|date('Y-m-d') }}" class="meta-chip">
                                {{ article.publishedAt|date('F j, Y') }}
                            </time>
                        {% endif %}
                        {% if article.readingTimeMinutes > 0 %}
                            <span class="meta-chip">{{ article.readingTimeMinutes }} min read</span>
                        {% endif %}
                        {% if article.isAiGenerated %}
                            <span class="badge-ai">AI</span>
                        {% endif %}
                    </div>

                    <h1 itemprop="headline">{{ article.title }}</h1>

                    {% if article.excerpt %}
                        <p class="text-muted" style="font-size:1.1rem;margin-bottom:1.5rem" itemprop="description">
                            {{ article.excerpt }}
                        </p>
                    {% endif %}
                </header>

                {# Featured Image #}
                {% if article.featuredImage %}
                    <div class="article-featured-image">
                        <img src="/uploads/{{ article.featuredImage.path }}"
                             alt="{{ article.featuredImage.altText ?? article.title }}"
                             loading="eager"
                             itemprop="image">
                    </div>
                {% endif %}

                {# Content with sticky ToC sidebar #}
                <div class="article-with-toc">
                    {# ToC sidebar (populated by toc.js) #}
                    <aside id="article-toc-sidebar" class="article-toc-sidebar" aria-label="Table of contents">
                        <nav class="toc">
                            <h2 class="toc-title">Contents</h2>
                            <ol id="toc-list" class="toc-list"></ol>
                        </nav>
                    </aside>

                    {# Article body #}
                    <div id="article-body" class="article-content" itemprop="articleBody">
                        {{ article.content|raw }}
                    </div>
                </div>

                {# Tags #}
                {% if article.tags is not empty %}
                    <div class="tags" style="margin-top:2rem">
                        {% for tag in article.tags %}
                            <a href="/tag/{{ tag.slug }}" class="tag">#{{ tag.name }}</a>
                        {% endfor %}
                    </div>
                {% endif %}

                {# Article Navigation #}
                {% if next_article is not null %}
                    <nav class="article-nav" style="margin-top:2.5rem;padding-top:1.5rem;border-top:1px solid var(--border)">
                        <div style="font-size:.75rem;text-transform:uppercase;letter-spacing:.05em;color:var(--text-muted);margin-bottom:.5rem">Next Article</div>
                        <a href="/{{ next_article.category ? next_article.category.slug ~ '/' : '' }}{{ next_article.slug }}" style="font-size:1.05rem;font-weight:600">
                            {{ next_article.title }}
                        </a>
                    </nav>
                {% endif %}

            </article>

            {# ── Sidebar ──────────────────────────── #}
            <aside class="sidebar">
                {{ include('components/sidebar.html.twig', {categories: categories}) }}
                {{ include('components/crypto_sidebar.html.twig') }}
            </aside>
        </div>

        {# ── Related Articles ──────────────────── #}
        {% if related_articles is not empty %}
            <section style="margin-top:3rem">
                <div class="section-header">
                    <h2>Related Articles</h2>
                    <a href="/{{ category.slug }}/">More in {{ category.name }} →</a>
                </div>
                <div class="related-grid">
                    {% for related in related_articles|slice(0, 3) %}
                        {{ include('components/article_card.html.twig', {article: related}) }}
                    {% endfor %}
                </div>
            </section>
        {% endif %}
    </div>

    {# Read Next bar (fixed bottom bar, shown when user scrolls past article) #}
    {% set read_next = next_article ?? (related_articles is not empty ? related_articles|first : null) %}
    {% if read_next is not null %}
        <div id="read-next-bar" class="read-next-bar" hidden>
            <span class="read-next-label">Read next</span>
            <a href="/{{ read_next.category ? read_next.category.slug ~ '/' : '' }}{{ read_next.slug }}" class="read-next-link">{{ read_next.title }}</a>
        </div>
    {% endif %}

{% endblock %}
