{% extends 'base.html.twig' %}

{% block title %}{{ meta_title }}{% endblock %}

{% block body %}

<div class="container">
<div class="layout">
<div>

    {# Breadcrumbs #}
    <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span>›</span>
        <a href="/tools/converter">Tools</a>
        <span>›</span>
        <span>Fear & Greed Index</span>
    </nav>

    <div class="page-header" style="text-align:center">
        <h1>Crypto Fear &amp; Greed Index</h1>
        <p class="page-intro">Market sentiment indicator — updated daily</p>
    </div>

    {# ── Gauge ──────────────────────────────────────────────── #}
    <div class="fg-gauge-wrap">
        {% set value = current.value %}

        <svg viewBox="0 0 200 120" class="fg-gauge" aria-label="Fear and Greed gauge: {{ value }} - {{ current.classification }}">
            {# Background arc #}
            <path d="M 20 100 A 80 80 0 0 1 180 100" fill="none" stroke="#e5e7eb" stroke-width="20" stroke-linecap="round"/>
            {# Extreme Fear 0-25 #}
            <path d="M 20 100 A 80 80 0 0 1 60 27" fill="none" stroke="#ea4335" stroke-width="20" stroke-linecap="butt" opacity="0.9"/>
            {# Fear 25-45 #}
            <path d="M 60 27 A 80 80 0 0 1 100 20" fill="none" stroke="#fbbc05" stroke-width="20" stroke-linecap="butt" opacity="0.9"/>
            {# Neutral 45-55 #}
            <path d="M 100 20 A 80 80 0 0 1 130 27" fill="none" stroke="#9e9e9e" stroke-width="20" stroke-linecap="butt" opacity="0.9"/>
            {# Greed 55-75 #}
            <path d="M 130 27 A 80 80 0 0 1 165 60" fill="none" stroke="#34a853" stroke-width="20" stroke-linecap="butt" opacity="0.9"/>
            {# Extreme Greed 75-100 #}
            <path d="M 165 60 A 80 80 0 0 1 180 100" fill="none" stroke="#1a73e8" stroke-width="20" stroke-linecap="round" opacity="0.9"/>

            {# Needle — positioned by JS on DOMContentLoaded #}
            <line id="fg-needle"
                  x1="100" y1="100"
                  x2="100" y2="30"
                  stroke="#1f2937" stroke-width="2.5" stroke-linecap="round"
                  data-value="{{ value }}"/>
            <circle cx="100" cy="100" r="5" fill="#1f2937"/>

            {# Value text #}
            <text x="100" y="82" text-anchor="middle" font-size="28" font-weight="700" fill="{{ zone_color }}">{{ value }}</text>
            <text x="100" y="97" text-anchor="middle" font-size="11" fill="#6b7280">{{ current.classification }}</text>
        </svg>

        <div class="fg-label" style="color:{{ zone_color }}">
            <span class="fg-value">{{ value }}</span>
            <span class="fg-classification">{{ current.classification }}</span>
        </div>
        <div class="fg-date">{{ current.date|date('F j, Y') }}</div>
    </div>

    {# ── Summary table ─────────────────────────────────────── #}
    <div class="fg-summary">
        <table class="data-table">
            <thead>
                <tr><th>Period</th><th>Value</th><th>Sentiment</th></tr>
            </thead>
            <tbody>
                {% for label, item in summary %}
                    {% if item is not null %}
                        {% set c = item.value <= 25 ? '#ea4335' : (item.value <= 45 ? '#fbbc05' : (item.value <= 55 ? '#9e9e9e' : (item.value <= 75 ? '#34a853' : '#1a73e8'))) %}
                        <tr>
                            <td>{{ label }}</td>
                            <td style="font-weight:600;color:{{ c }}">{{ item.value }}</td>
                            <td>{{ item.classification }}</td>
                        </tr>
                    {% endif %}
                {% endfor %}
            </tbody>
        </table>
    </div>

    {# ── 30-day history chart ──────────────────────────────── #}
    {% if history|length > 1 %}
        <div class="fg-history-wrap">
            <h2>30-Day History</h2>
            <canvas id="fg-chart" height="120" aria-label="Fear and Greed 30-day chart"></canvas>
        </div>
    {% endif %}

    {# ── Historical table ──────────────────────────────────── #}
    <div class="fg-history-table">
        <h2>Daily Values</h2>
        <table class="data-table">
            <thead>
                <tr><th>Date</th><th>Value</th><th>Classification</th></tr>
            </thead>
            <tbody>
                {% for item in history %}
                    {% set c = item.value <= 25 ? '#ea4335' : (item.value <= 45 ? '#fbbc05' : (item.value <= 55 ? '#9e9e9e' : (item.value <= 75 ? '#34a853' : '#1a73e8'))) %}
                    <tr>
                        <td>{{ item.date|date('M j, Y') }}</td>
                        <td style="font-weight:600;color:{{ c }}">{{ item.value }}</td>
                        <td>{{ item.classification }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {# ── Explainer ─────────────────────────────────────────── #}
    <section class="fg-explainer">
        <h2>What is the Crypto Fear &amp; Greed Index?</h2>
        <p>The Crypto Fear &amp; Greed Index measures market sentiment on a scale from 0 (Extreme Fear) to 100 (Extreme Greed). It was created by Alternative.me and aggregates data from six sources:</p>
        <ul>
            <li><strong>Volatility (25%):</strong> Current BTC volatility vs 30/90-day averages</li>
            <li><strong>Market Momentum/Volume (25%):</strong> Current trading volume vs 30/90-day averages</li>
            <li><strong>Social Media (15%):</strong> Twitter/Reddit hashtag activity and sentiment</li>
            <li><strong>Surveys (15%):</strong> Weekly polls (currently paused)</li>
            <li><strong>Bitcoin Dominance (10%):</strong> BTC's share of total crypto market cap</li>
            <li><strong>Google Trends (10%):</strong> Bitcoin-related search queries</li>
        </ul>

        <h2>What Does Each Zone Mean?</h2>
        <div class="fg-zones">
            <div class="fg-zone" style="border-left:4px solid #ea4335"><strong>0–25: Extreme Fear</strong> — Investors are very worried. Historically a potential buying opportunity.</div>
            <div class="fg-zone" style="border-left:4px solid #fbbc05"><strong>26–45: Fear</strong> — Market caution. Prices may still fall.</div>
            <div class="fg-zone" style="border-left:4px solid #9e9e9e"><strong>46–55: Neutral</strong> — Balanced sentiment. No strong signal.</div>
            <div class="fg-zone" style="border-left:4px solid #34a853"><strong>56–75: Greed</strong> — Investors are optimistic. Caution advised.</div>
            <div class="fg-zone" style="border-left:4px solid #1a73e8"><strong>76–100: Extreme Greed</strong> — Market overheated. Historically precedes corrections.</div>
        </div>

        <h2>FAQ</h2>
        <details class="faq-item">
            <summary>Should I buy when fear is high?</summary>
            <div class="faq-answer">Warren Buffett famously said "Be fearful when others are greedy, and greedy when others are fearful." Historically, extreme fear periods have coincided with market bottoms, but this is not guaranteed. Never invest more than you can afford to lose.</div>
        </details>
        <details class="faq-item">
            <summary>How often is the index updated?</summary>
            <div class="faq-answer">The Fear &amp; Greed Index is updated once per day, typically in the early hours UTC. Our page refreshes the data every 30 minutes.</div>
        </details>
        <details class="faq-item">
            <summary>Is this only for Bitcoin?</summary>
            <div class="faq-answer">The index primarily measures Bitcoin sentiment but serves as a general crypto market indicator. Since Bitcoin price movements heavily influence the entire market, it reflects broad crypto sentiment.</div>
        </details>
    </section>

    {# Related links #}
    <div class="related-links">
        <h3>Related</h3>
        <ul>
            <li><a href="/price/bitcoin">Bitcoin Price</a></li>
            <li><a href="/price/ethereum">Ethereum Price</a></li>
            <li><a href="/tools/crypto-profit-calculator">Profit/Loss Calculator</a></li>
            <li><a href="/tools/dca-calculator">DCA Calculator</a></li>
            <li><a href="/glossary">Crypto Glossary</a></li>
        </ul>
    </div>

</div>{# /main col #}

<aside class="sidebar">
    {{ include('components/crypto_sidebar.html.twig') }}
    {{ include('components/sidebar.html.twig', {categories: categories}) }}
</aside>
</div>{# /layout #}
</div>

{# ── JSON-LD ─────────────────────────────────────────────────────── #}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "Dataset",
    "name": "Crypto Fear & Greed Index",
    "description": "Daily cryptocurrency market sentiment index from 0 (Extreme Fear) to 100 (Extreme Greed).",
    "url": "{{ app.request.schemeAndHttpHost }}/fear-greed-index",
    "temporalCoverage": "2018-02/",
    "measurementTechnique": "Composite of volatility, volume, social media, Bitcoin dominance and Google Trends"
}
</script>

<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
        {
            "@type": "Question",
            "name": "What is the Crypto Fear and Greed Index?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "The Crypto Fear & Greed Index measures market sentiment on a scale from 0 (Extreme Fear) to 100 (Extreme Greed), aggregating data from volatility, trading volume, social media, Bitcoin dominance, and Google Trends."
            }
        },
        {
            "@type": "Question",
            "name": "Should I buy when fear is high?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Historically, extreme fear periods have coincided with market bottoms, but this is not guaranteed. The index is a sentiment tool, not financial advice. Always do your own research."
            }
        }
    ]
}
</script>

{# ── Needle positioning ─────────────────────────────────────────── #}
<script>
(function() {
    var needle = document.getElementById('fg-needle');
    if (!needle) return;
    var value  = parseInt(needle.dataset.value, 10);
    // Map 0..100 → 180°..0° (left to right semicircle)
    var angleDeg = 180 - (value / 100 * 180);
    var rad   = angleDeg * Math.PI / 180;
    var x2    = 100 + 70 * Math.cos(rad);
    var y2    = 100 - 70 * Math.sin(rad);
    needle.setAttribute('x2', x2.toFixed(2));
    needle.setAttribute('y2', y2.toFixed(2));
})();
</script>

{# ── Chart.js via CDN (lightweight) ─────────────────────────────── #}
{% if history|length > 1 %}
<script>
(function() {
    var history = {{ history|json_encode|raw }};
    var labels  = history.slice().reverse().map(function(d) {
        var date = new Date(d.timestamp * 1000);
        return (date.getMonth()+1) + '/' + date.getDate();
    });
    var values  = history.slice().reverse().map(function(d) { return d.value; });
    var colors  = values.map(function(v) {
        if (v <= 25)  return '#ea4335';
        if (v <= 45)  return '#fbbc05';
        if (v <= 55)  return '#9e9e9e';
        if (v <= 75)  return '#34a853';
        return '#1a73e8';
    });

    var canvas = document.getElementById('fg-chart');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    var W = canvas.offsetWidth || 800;
    canvas.width  = W;
    canvas.height = 120;

    var padL = 30, padR = 10, padT = 10, padB = 20;
    var chartW = W - padL - padR;
    var chartH = 120 - padT - padB;
    var step   = chartW / (values.length - 1);

    // Grid lines
    ctx.strokeStyle = '#e5e7eb';
    ctx.lineWidth   = 1;
    [25, 50, 75].forEach(function(v) {
        var y = padT + chartH - (v / 100 * chartH);
        ctx.beginPath(); ctx.moveTo(padL, y); ctx.lineTo(W - padR, y); ctx.stroke();
        ctx.fillStyle = '#9e9e9e'; ctx.font = '9px sans-serif';
        ctx.fillText(v, 0, y + 3);
    });

    // Line
    ctx.beginPath();
    values.forEach(function(v, i) {
        var x = padL + i * step;
        var y = padT + chartH - (v / 100 * chartH);
        if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
    });
    ctx.strokeStyle = '#6366f1';
    ctx.lineWidth   = 2;
    ctx.stroke();

    // Dots
    values.forEach(function(v, i) {
        var x = padL + i * step;
        var y = padT + chartH - (v / 100 * chartH);
        ctx.beginPath();
        ctx.arc(x, y, 3, 0, Math.PI * 2);
        ctx.fillStyle = colors[i];
        ctx.fill();
    });
})();
</script>
{% endif %}

{% endblock %}
