# Application
APP_ENV=dev
APP_SECRET=changeme_generate_with_openssl_rand_hex_32
APP_SHARE_DIR=var/share

# Database (MySQL via Docker service "mysql")
DATABASE_URL="mysql://app:secret@mysql:3306/multisite?charset=utf8mb4&serverVersion=8.4.0"

# Redis
REDIS_URL=redis://redis:6379

# Symfony Messenger (via Redis)
MESSENGER_TRANSPORT_DSN=redis://redis:6379/messages

# Docker credentials (used by docker-compose)
MYSQL_ROOT_PASSWORD=root
MYSQL_PASSWORD=secret

# n8n
N8N_USER=admin
N8N_PASSWORD=admin

# Admin panel (HTTP Basic Auth, prod only)
# Generate: docker-compose run --rm --user root php php bin/console security:hash-password
ADMIN_PASSWORD_HASH='$2y$13$adminpassword'

# Routing (for CLI commands)
DEFAULT_URI=http://localhost
ANTHROPIC_API_KEY=

# Etherscan Gas Tracker API (free key from etherscan.io/apis)
ETHERSCAN_API_KEY=
